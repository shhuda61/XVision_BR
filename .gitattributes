# Auto detect text files
* text=auto

# C# source
*.cs text diff=csharp

# Unity assets
*.meta text
*.unity text
*.prefab text
*.asset text
*.mat text
*.anim text
*.controller text

# Line endings
*.sh text eol=lf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.psd binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.ogg binary